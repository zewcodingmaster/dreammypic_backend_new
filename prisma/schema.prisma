// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  email       String?
  phoneNumber String?

  currentAccountBalance          Int?                             @default(9)
  // passwordHash  String
  otplessUserId                  String?                          @unique
  UserImageGenerationRequestLogs UserImageGenerationRequestLogs[]
  UserPaymendLogs                UserPaymendLogs[]
}

enum GenerationStatus {
  PENDING
  COMPLETED
  FAILED
}

model UserPaymendLogs {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId

  amount Int

  paymentId String? @unique
  orderId   String  @unique

  userId String @db.ObjectId
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime
}

model UserImageGenerationRequestLogs {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  userOtplessUserId String?
  imageUrl          String?
  generationStatus  GenerationStatus
  runpodRequestId   String           @unique

  userId String @db.ObjectId
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  requestedAt DateTime @default(now())
}

model email_otp {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique
  otp   String

  created_at DateTime @default(now())
}
